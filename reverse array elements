#include <stdio.h>
int main() {
    int num[100], n, i;
    printf("Enter number:");
    scanf("%d", &n);

    printf("Enter the value:");
    for (i = 0; i < n; i++) {
        scanf("%d", &num[i]);
    }

    printf("The elements are:\n");
    for (i = 0; i < n; i++) {
        printf("%d\t", num[i]);
    }

    printf("\nReverse order:\n");
    for (i = n - 1; i >= 0; i--) {
        printf("%d\t", num[i]);
    }
    return 0;
}
